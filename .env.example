# 复制为 .env：docker compose --env-file .env up -d --build
# 构建不拉远程基镜像：docker compose build --pull=false

# 国内 Hub 拉取失败时设置前缀（末尾带 /）：
# REGISTRY_PREFIX=docker.m.daocloud.io/library/
# REGISTRY_PREFIX=registry.cn-hangzhou.aliyuncs.com/library/
REGISTRY_PREFIX=

MAVEN_BUILD_IMAGE=maven:3.9.9-eclipse-temurin-21
JAVA_RUN_IMAGE=eclipse-temurin:21-jre-jammy
NODE_IMAGE=node:20-alpine
NGINX_IMAGE=nginx:alpine
MYSQL_BASE_IMAGE=mysql:8.0
POSTGRES_IMAGE=postgres:16-alpine
ES_IMAGE=elasticsearch:8.15.3
RUSTFS_IMAGE=rustfs/rustfs:latest
